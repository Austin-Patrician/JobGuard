# Local Environment Variables
NEXT_PUBLIC_APP_NAME=JobGuard
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=your-openai-key
OPENAI_API_BASE_URL=https://api.routin.ai/v1
AI_MODEL=gpt-4.1

# Postgres
DATABASE_URL=postgres://user:password@host:5432/jobguard
PGSSLMODE=require

# Security
IP_HASH_SALT=random-salt-string
