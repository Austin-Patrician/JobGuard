# Environment Variables
# Copy this file to .env.local and fill in actual values

# App
NEXT_PUBLIC_APP_NAME=JobGuard
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (example)
# DATABASE_URL=postgresql://user:password@localhost:5432/jobguard

# Auth (example)
# AUTH_SECRET=your-secret-key
# AUTH_URL=http://localhost:3000

# OpenAI-compatible API (for toolkit AI analysis)
OPENAI_API_KEY=your-api-key
OPENAI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Security
IP_HASH_SALT=random-salt-string
